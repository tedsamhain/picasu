{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "API Scenario DSL Schema",
  "description": "Validates API scenario YAML files in tests/scenarios/ and tests/scenarios/selftest/.",
  "$ref": "#/definitions/apiScenario",
  "definitions": {
    "givenDirAlbum": {
      "type": "object",
      "properties": {
        "dir_album": { "type": "string" },
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }
      },
      "required": ["dir_album"],
      "additionalProperties": false
    },
    "givenPhoto": {
      "type": "object",
      "properties": {
        "photo": { "type": "string" },
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "exif_date": { "type": "string" },
        "color": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 255 },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "required": ["photo"],
      "additionalProperties": false
    },
    "givenRemove": {
      "type": "object",
      "properties": {
        "remove": { "type": "string" }
      },
      "required": ["remove"],
      "additionalProperties": false
    },
    "givenEmpty": {
      "type": "object",
      "properties": {
        "empty": { "type": "boolean", "const": true }
      },
      "required": ["empty"],
      "additionalProperties": false
    },
    "givenConfig": {
      "type": "object",
      "properties": {
        "config": {
          "type": "object",
          "properties": {
            "read_only_mode": { "type": "boolean" }
          },
          "required": ["read_only_mode"],
          "additionalProperties": false
        }
      },
      "required": ["config"],
      "additionalProperties": false
    },
    "givenItem": {
      "oneOf": [
        { "$ref": "#/definitions/givenDirAlbum" },
        { "$ref": "#/definitions/givenPhoto" },
        { "$ref": "#/definitions/givenEmpty" },
        { "$ref": "#/definitions/givenRemove" },
        { "$ref": "#/definitions/givenConfig" }
      ]
    },
    "apiCall": {
      "type": "object",
      "properties": {
        "call": { "type": "string", "pattern": "^(GET|POST|PUT|DELETE) /" },
        "body": { "type": "object" },
        "auth": { "type": "boolean", "default": true },
        "capture": { "type": "object" },
        "calc": { "type": "object" },
        "then": { "type": "array" }
      },
      "required": ["call"],
      "additionalProperties": false
    },
    "apiThenResponseStatus": {
      "type": "object",
      "properties": {
        "response.status": { "type": "integer", "minimum": 100, "maximum": 599 }
      },
      "required": ["response.status"],
      "additionalProperties": false
    },
    "apiThenResponseStatusNot": {
      "type": "object",
      "properties": {
        "response.status_not": { "type": "integer", "minimum": 100, "maximum": 599 }
      },
      "required": ["response.status_not"],
      "additionalProperties": false
    },
    "apiThenResponseField": {
      "type": "object",
      "patternProperties": {
        "^response\\.[a-zA-Z_][a-zA-Z0-9_.]*$": {
          "oneOf": [
            { "type": "string" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        }
      },
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": false
    },
    "apiThenArrayMinCounts": {
      "type": "object",
      "properties": {
        "array_min_counts": { "type": "object" }
      },
      "required": ["array_min_counts"],
      "additionalProperties": false
    },
    "apiThenArrayWhere": {
      "type": "object",
      "properties": {
        "array_where": { "type": "object" }
      },
      "required": ["array_where"],
      "additionalProperties": false
    },
    "apiThenFileExists": {
      "type": "object",
      "properties": {
        "file_exists": { "type": "string" }
      },
      "required": ["file_exists"],
      "additionalProperties": false
    },
    "apiThenFileAbsent": {
      "type": "object",
      "properties": {
        "file_absent": { "type": "string" }
      },
      "required": ["file_absent"],
      "additionalProperties": false
    },
    "apiThenServeImageOk": {
      "type": "object",
      "properties": {
        "serve_image_ok": { "type": "string" }
      },
      "required": ["serve_image_ok"],
      "additionalProperties": false
    },
    "apiThenItem": {
      "oneOf": [
        { "$ref": "#/definitions/apiThenResponseStatus" },
        { "$ref": "#/definitions/apiThenResponseStatusNot" },
        { "$ref": "#/definitions/apiThenResponseField" },
        { "$ref": "#/definitions/apiThenArrayMinCounts" },
        { "$ref": "#/definitions/apiThenArrayWhere" },
        { "$ref": "#/definitions/apiThenFileExists" },
        { "$ref": "#/definitions/apiThenFileAbsent" },
        { "$ref": "#/definitions/apiThenServeImageOk" }
      ]
    },
    "apiScenario": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "given": {
          "type": "array",
          "items": { "$ref": "#/definitions/givenItem" },
          "minItems": 0
        },
        "when": {
          "oneOf": [
            { "$ref": "#/definitions/apiCall" },
            {
              "type": "array",
              "items": { "$ref": "#/definitions/apiCall" },
              "minItems": 1
            }
          ]
        },
        "then": {
          "type": "array",
          "items": { "$ref": "#/definitions/apiThenItem" },
          "minItems": 1
        }
      },
      "required": ["name", "when", "then"],
      "additionalProperties": false
    }
  }
}
