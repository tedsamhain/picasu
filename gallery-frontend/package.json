{
  "name": "gallery-frontend",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm ci && vue-tsc --noEmit && vite build",
    "build:only": "vue-tsc --noEmit && vite build",
    "check": "npx vue-tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "generateLexer": "ts-node-esm ./src/script/lexer/generateCstDts.ts",
    "test": "vitest run --reporter=verbose",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@misskey-dev/browser-image-resizer": "^2024.1.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.0",
    "axios-retry": "^4.5.0",
    "chevrotain": "^12.0.0",
    "delay": "^7.0.0",
    "file-saver": "^2.0.5",
    "filesize": "^11.0.17",
    "humanize-duration": "^3.33.2",
    "is-mobile": "^5.0.0",
    "js-cookie": "^3.0.8",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.18.1",
    "pinia": "^3.0.4",
    "swiper": "^12.2.0",
    "thumbhash": "^0.1.1",
    "typesafe-agent-events": "^1.0.2",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vuetify": "^4.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/file-saver": "^2.0.7",
    "@types/humanize-duration": "^3.27.4",
    "@types/js-cookie": "^3.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "path-browserify": "^1.0.1",
    "sass-embedded": "^1.100.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "upath": "^3.0.7",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "prettier": {
    "$schema": "https://json.schemastore.org/prettierrc",
    "semi": false,
    "tabWidth": 2,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "none"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.0",
    "rollup": "^4.59.0",
    "minimatch": "^10.2.3",
    "serialize-javascript": "^7.0.5",
    "immutable": "^5.1.5",
    "flatted": "^3.4.2",
    "follow-redirects": "^1.16.0",
    "picomatch": "^4.0.4",
    "yaml": "^2.8.3",
    "axios": "^1.18.0",
    "brace-expansion": "^5.0.5"
