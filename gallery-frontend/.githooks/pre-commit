#!/bin/sh
# Pre-commit checks for gallery-frontend.
# Install once per clone:
#   git config core.hooksPath gallery-frontend/.githooks
set -e

cd "$(git rev-parse --show-toplevel)/gallery-frontend"

echo "[ pre-commit ] prettier..."
npx prettier --check .

echo "[ pre-commit ] tsc..."
npx vue-tsc --noEmit

echo "[ pre-commit ] eslint..."
npx eslint .

echo "[ pre-commit ] ok"
