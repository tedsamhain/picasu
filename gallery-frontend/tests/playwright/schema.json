{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UI Scenario DSL Schema",
  "description": "Validates UI scenario YAML files in tests/playwright/scenarios/.",
  "$ref": "#/definitions/uiScenario",
  "definitions": {
    "givenDirAlbum": {
      "type": "object",
      "properties": {
        "dir_album": { "type": "string" },
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }
      },
      "required": ["dir_album"],
      "additionalProperties": false
    },
    "givenPhoto": {
      "type": "object",
      "properties": {
        "photo": { "type": "string" },
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" },
        "format": { "type": "string", "enum": ["jpeg", "png"] },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "seed": { "type": "integer", "minimum": 0 },
        "tags": { "type": "array", "items": { "type": "string" } },
        "exif_date": { "type": "string" },
        "color": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 255 },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "required": ["photo"],
      "additionalProperties": false
    },
    "givenRemove": {
      "type": "object",
      "properties": {
        "remove": { "type": "string" }
      },
      "required": ["remove"],
      "additionalProperties": false
    },
    "givenEmpty": {
      "type": "object",
      "properties": {
        "empty": { "type": "boolean", "const": true }
      },
      "required": ["empty"],
      "additionalProperties": false
    },
    "givenConfig": {
      "type": "object",
      "properties": {
        "config": {
          "type": "object",
          "properties": {
            "read_only_mode": { "type": "boolean" },
            "password": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "required": ["config"],
      "additionalProperties": false
    },
    "givenItem": {
      "oneOf": [
        { "$ref": "#/definitions/givenDirAlbum" },
        { "$ref": "#/definitions/givenPhoto" },
        { "$ref": "#/definitions/givenEmpty" },
        { "$ref": "#/definitions/givenRemove" },
        { "$ref": "#/definitions/givenConfig" }
      ]
    },
    "uiWhenNavigate": {
      "type": "object",
      "properties": {
        "navigate": { "type": "string" }
      },
      "required": ["navigate"],
      "additionalProperties": false
    },
    "uiWhenClick": {
      "type": "object",
      "properties": {
        "click": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["click"],
      "additionalProperties": false
    },
    "uiWhenFill": {
      "type": "object",
      "properties": {
        "fill": { "type": "string", "pattern": "^[a-z]+/" },
        "value": { "type": "string" }
      },
      "required": ["fill", "value"],
      "additionalProperties": false
    },
    "uiWhenSelect": {
      "type": "object",
      "properties": {
        "select": { "type": "string", "pattern": "^[a-z]+/" },
        "option": { "type": "string" }
      },
      "required": ["select", "option"],
      "additionalProperties": false
    },
    "uiWhenSubmit": {
      "type": "object",
      "properties": {
        "submit": { "type": "boolean", "const": true }
      },
      "required": ["submit"],
      "additionalProperties": false
    },
    "uiWhenItem": {
      "oneOf": [
        { "$ref": "#/definitions/uiWhenNavigate" },
        { "$ref": "#/definitions/uiWhenClick" },
        { "$ref": "#/definitions/uiWhenFill" },
        { "$ref": "#/definitions/uiWhenSelect" },
        { "$ref": "#/definitions/uiWhenSubmit" }
      ]
    },
    "uiThenVisible": {
      "type": "object",
      "properties": {
        "ui.visible": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["ui.visible"],
      "additionalProperties": false
    },
    "uiThenHidden": {
      "type": "object",
      "properties": {
        "ui.hidden": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["ui.hidden"],
      "additionalProperties": false
    },
    "uiThenText": {
      "type": "object",
      "properties": {
        "ui.text": { "type": "string", "pattern": "^[a-z]+/" },
        "contains": { "type": "string" }
      },
      "required": ["ui.text", "contains"],
      "additionalProperties": false
    },
    "uiThenToast": {
      "type": "object",
      "properties": {
        "ui.toast": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["error", "success", "warning"] },
            "contains": { "type": "string" }
          },
          "required": ["type", "contains"],
          "additionalProperties": false
        }
      },
      "required": ["ui.toast"],
      "additionalProperties": false
    },
    "uiThenModal": {
      "type": "object",
      "properties": {
        "ui.modal": { "type": "string", "enum": ["open", "closed"] }
      },
      "required": ["ui.modal"],
      "additionalProperties": false
    },
    "uiThenRoute": {
      "type": "object",
      "properties": {
        "ui.route": { "type": "string" }
      },
      "required": ["ui.route"],
      "additionalProperties": false
    },
    "uiThenAriaSnapshot": {
      "type": "object",
      "properties": {
        "ui.aria_snapshot": { "type": "string" }
      },
      "required": ["ui.aria_snapshot"],
      "additionalProperties": false
    },
    "uiThenItem": {
      "oneOf": [
        { "$ref": "#/definitions/uiThenVisible" },
        { "$ref": "#/definitions/uiThenHidden" },
        { "$ref": "#/definitions/uiThenText" },
        { "$ref": "#/definitions/uiThenToast" },
        { "$ref": "#/definitions/uiThenModal" },
        { "$ref": "#/definitions/uiThenRoute" },
        { "$ref": "#/definitions/uiThenAriaSnapshot" }
      ]
    },
    "covers": {
      "type": "object",
      "properties": {
        "api": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ui": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "uiScenario": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "covers": { "$ref": "#/definitions/covers" },
        "given": {
          "type": "array",
          "items": { "$ref": "#/definitions/givenItem" },
          "minItems": 0
        },
        "when": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiWhenItem" },
          "minItems": 1
        },
        "then": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiThenItem" },
          "minItems": 1
        }
      },
      "required": ["name", "when", "then"],
      "additionalProperties": false
    }
  }
}
