{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UI Scenario DSL Schema",
  "description": "Validates UI scenario YAML files in tests/playwright/scenarios/.",
  "$ref": "#/definitions/uiScenario",
  "definitions": {
    "givenDirAlbum": {
      "type": "object",
      "properties": {
        "dir_album": { "type": "string" },
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }
      },
      "required": ["dir_album"],
      "additionalProperties": false
    },
    "givenPhoto": {
      "type": "object",
      "properties": {
        "photo": { "type": "string" },
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" },
        "format": { "type": "string", "enum": ["jpeg", "png"] },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "tags": { "type": "array", "items": { "type": "string" } },
        "exif_date": { "type": "string" }
      },
      "required": ["photo"],
      "additionalProperties": false
    },
    "givenRemove": {
      "type": "object",
      "properties": {
        "remove": { "type": "string" }
      },
      "required": ["remove"],
      "additionalProperties": false
    },
    "givenMove": {
      "type": "object",
      "properties": {
        "move": { "type": "string" },
        "to": { "type": "string" }
      },
      "required": ["move", "to"],
      "additionalProperties": false
    },
    "givenEmpty": {
      "type": "object",
      "properties": {
        "empty": { "type": "boolean", "const": true }
      },
      "required": ["empty"],
      "additionalProperties": false
    },
    "givenConfig": {
      "type": "object",
      "properties": {
        "config": {
          "type": "object",
          "properties": {
            "read_only_mode": { "type": "boolean" },
            "password": { "type": "string" },
            "image_path": { "oneOf": [{ "type": "boolean" }, { "type": "string" }] },
            "auth_key": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "required": ["config"],
      "additionalProperties": false
    },
    "givenItem": {
      "oneOf": [
        { "$ref": "#/definitions/givenDirAlbum" },
        { "$ref": "#/definitions/givenPhoto" },
        { "$ref": "#/definitions/givenEmpty" },
        { "$ref": "#/definitions/givenRemove" },
        { "$ref": "#/definitions/givenConfig" },
        { "$ref": "#/definitions/givenMove" }
      ]
    },
    "uiWhenNavigate": {
      "type": "object",
      "properties": {
        "navigate": { "type": "string" }
      },
      "required": ["navigate"],
      "additionalProperties": false
    },
    "uiWhenClick": {
      "type": "object",
      "properties": {
        "click": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["click"],
      "additionalProperties": false
    },
    "uiWhenFill": {
      "type": "object",
      "properties": {
        "fill": { "type": "string", "pattern": "^[a-z]+/" },
        "value": { "type": "string" }
      },
      "required": ["fill", "value"],
      "additionalProperties": false
    },
    "uiWhenSelect": {
      "type": "object",
      "properties": {
        "select": { "type": "string", "pattern": "^[a-z]+/" },
        "option": { "type": "string" }
      },
      "required": ["select", "option"],
      "additionalProperties": false
    },
    "uiWhenSubmit": {
      "type": "object",
      "properties": {
        "submit": { "type": "boolean", "const": true }
      },
      "required": ["submit"],
      "additionalProperties": false
    },
    "uiWhenWait": {
      "type": "object",
      "properties": {
        "wait.ms": { "type": "integer", "minimum": 1 }
      },
      "required": ["wait.ms"],
      "additionalProperties": false
    },
    "uiWhenClickText": {
      "type": "object",
      "properties": {
        "click.text": { "type": "string" }
      },
      "required": ["click.text"],
      "additionalProperties": false
    },
    "uiWhenClickIcon": {
      "type": "object",
      "properties": {
        "click.icon": { "type": "string" }
      },
      "required": ["click.icon"],
      "additionalProperties": false
    },
    "uiWhenItem": {
      "oneOf": [
        { "$ref": "#/definitions/uiWhenNavigate" },
        { "$ref": "#/definitions/uiWhenClick" },
        { "$ref": "#/definitions/uiWhenFill" },
        { "$ref": "#/definitions/uiWhenSelect" },
        { "$ref": "#/definitions/uiWhenSubmit" },
        { "$ref": "#/definitions/uiWhenWait" },
        { "$ref": "#/definitions/uiWhenClickText" },
        { "$ref": "#/definitions/uiWhenClickIcon" }
      ]
    },
    "uiAssertVisible": {
      "type": "object",
      "properties": {
        "ui.visible": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["ui.visible"],
      "additionalProperties": false
    },
    "uiAssertHidden": {
      "type": "object",
      "properties": {
        "ui.hidden": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["ui.hidden"],
      "additionalProperties": false
    },
    "uiAssertText": {
      "type": "object",
      "properties": {
        "ui.text": { "type": "string", "pattern": "^[a-z]+/" },
        "contains": { "type": "string" }
      },
      "required": ["ui.text", "contains"],
      "additionalProperties": false
    },
    "uiAssertToast": {
      "type": "object",
      "properties": {
        "ui.toast": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["error", "success", "warning"] },
            "contains": { "type": "string" }
          },
          "required": ["type", "contains"],
          "additionalProperties": false
        }
      },
      "required": ["ui.toast"],
      "additionalProperties": false
    },
    "uiAssertModal": {
      "type": "object",
      "properties": {
        "ui.modal": { "type": "string", "enum": ["open", "closed"] }
      },
      "required": ["ui.modal"],
      "additionalProperties": false
    },
    "uiAssertRoute": {
      "type": "object",
      "properties": {
        "ui.route": { "type": "string" }
      },
      "required": ["ui.route"],
      "additionalProperties": false
    },
    "uiAssertAriaSnapshot": {
      "type": "object",
      "properties": {
        "ui.aria_snapshot": { "type": "string" }
      },
      "required": ["ui.aria_snapshot"],
      "additionalProperties": false
    },
    "uiAssertApiResponse": {
      "type": "object",
      "properties": {
        "api.response": {
          "type": "object",
          "properties": {
            "url": { "type": "string" },
            "status": {
              "oneOf": [{ "type": "integer" }, { "type": "array", "items": { "type": "integer" } }]
            }
          },
          "required": ["url", "status"],
          "additionalProperties": false
        }
      },
      "required": ["api.response"],
      "additionalProperties": false
    },
    "uiAssertTextVisible": {
      "type": "object",
      "properties": {
        "ui.text_visible": { "type": "string" }
      },
      "required": ["ui.text_visible"],
      "additionalProperties": false
    },
    "uiAssertCount": {
      "type": "object",
      "properties": {
        "ui.count": { "type": "string" },
        "equals": { "type": "integer", "minimum": 0 }
      },
      "required": ["ui.count", "equals"],
      "additionalProperties": false
    },
    "uiAssertItem": {
      "oneOf": [
        { "$ref": "#/definitions/uiAssertVisible" },
        { "$ref": "#/definitions/uiAssertHidden" },
        { "$ref": "#/definitions/uiAssertText" },
        { "$ref": "#/definitions/uiAssertToast" },
        { "$ref": "#/definitions/uiAssertModal" },
        { "$ref": "#/definitions/uiAssertRoute" },
        { "$ref": "#/definitions/uiAssertAriaSnapshot" },
        { "$ref": "#/definitions/uiAssertApiResponse" },
        { "$ref": "#/definitions/uiAssertTextVisible" },
        { "$ref": "#/definitions/uiAssertCount" }
      ]
    },
    "uiStep": {
      "type": "object",
      "properties": {
        "when": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiWhenItem" },
          "minItems": 1
        },
        "assert": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiAssertItem" },
          "minItems": 1
        }
      },
      "required": ["when", "assert"],
      "additionalProperties": false
    },
    "covers": {
      "type": "object",
      "properties": {
        "api": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ui": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "uiScenario": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "covers": { "$ref": "#/definitions/covers" },
        "given": {
          "type": "array",
          "items": { "$ref": "#/definitions/givenItem" },
          "minItems": 0
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiStep" },
          "minItems": 1
        },
        "when": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiWhenItem" },
          "minItems": 1
        },
        "assert": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiAssertItem" },
          "minItems": 1
        }
      },
      "required": ["name"],
      "oneOf": [
        { "required": ["steps"] },
        { "required": ["when", "assert"] }
      ],
      "additionalProperties": false
    }
  }
}
