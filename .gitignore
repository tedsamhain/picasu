# Ignore all log files at the root level
/*.log

# Prevent uploading development-related scripts and editor configuration files to the main branch
cleanup.sh
.vscode/

# User-specific configuration files, added to .gitignore to avoid overwriting during collaboration
backend/config.toml
backend/Rocket.toml
frontend/config.ts
.env

# Ignore build and generated files that should not be version-controlled
frontend/dist
frontend/node_modules
frontend/dev-dist
backend/target
backend/Cargo.lock
/target/
backend/test
backend/db
backend/object

# `just run`'s dev sandbox (data dir + test galleries, see docs/config.md)
/sandbox/

# E2E test execution environments (generated per run)
.testruns/

# Local compose overrides + the bind-mounted volume dirs from compose.yaml
compose.override.yaml
picasu-data/

# Ignore installer executables
*.exe

# backend/upload: A user-specific folder for media uploads, should not be tracked
backend/upload

# Ignore OpenCode config extensions
.opencode/oh-my-opencode.jsonc

/**/.omc

# just for local planning with AI
TODO.md
