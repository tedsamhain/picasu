#!/bin/sh
# Pre-commit checks for gallery-backend.
# Install once per clone:
#   git config core.hooksPath gallery-backend/.githooks
set -e

cd "$(git rev-parse --show-toplevel)/gallery-backend"

echo "[ pre-commit ] fmt..."
cargo fmt --check

echo "[ pre-commit ] clippy..."
cargo clippy -- -D warnings

echo "[ pre-commit ] test..."
cargo test --quiet

echo "[ pre-commit ] ok"
