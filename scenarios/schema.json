{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scenario DSL Schema",
  "description": "Validates YAML scenario files for both API (scenarios/api/) and UI (scenarios/ui/) targets.",
  "oneOf": [
    { "$ref": "#/definitions/apiScenario" },
    { "$ref": "#/definitions/uiScenario" }
  ],
  "definitions": {
    "idBinding": {
      "type": "object",
      "properties": {
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }
      },
      "required": [],
      "additionalProperties": false
    },
    "givenDirAlbum": {
      "type": "object",
      "properties": {
        "dir_album": { "type": "string" },
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }
      },
      "required": ["dir_album"],
      "additionalProperties": false
    },
    "givenPhoto": {
      "type": "object",
      "properties": {
        "photo": { "type": "string" },
        "id_as": { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "exif_date": { "type": "string" },
        "color": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 255 },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "required": ["photo"],
      "additionalProperties": false
    },
    "givenEmpty": {
      "type": "object",
      "properties": {
        "empty": { "type": "boolean", "const": true }
      },
      "required": ["empty"],
      "additionalProperties": false
    },
    "givenItem": {
      "oneOf": [
        { "$ref": "#/definitions/givenDirAlbum" },
        { "$ref": "#/definitions/givenPhoto" },
        { "$ref": "#/definitions/givenEmpty" }
      ]
    },
    "apiCall": {
      "type": "object",
      "properties": {
        "call": { "type": "string", "pattern": "^(GET|POST|PUT|DELETE) /" },
        "body": { "type": "object" },
        "auth": { "type": "boolean", "default": true }
      },
      "required": ["call"],
      "additionalProperties": false
    },
    "apiThenResponseStatus": {
      "type": "object",
      "properties": {
        "response.status": { "type": "integer", "minimum": 100, "maximum": 599 }
      },
      "required": ["response.status"],
      "additionalProperties": false
    },
    "apiThenResponseField": {
      "type": "object",
      "patternProperties": {
        "^response\\.[a-zA-Z_][a-zA-Z0-9_.]*$": {
          "oneOf": [
            { "type": "string" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        }
      },
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": false
    },
    "apiThenFileExists": {
      "type": "object",
      "properties": {
        "file_exists": { "type": "string" }
      },
      "required": ["file_exists"],
      "additionalProperties": false
    },
    "apiThenFileAbsent": {
      "type": "object",
      "properties": {
        "file_absent": { "type": "string" }
      },
      "required": ["file_absent"],
      "additionalProperties": false
    },
    "apiThenDbImage": {
      "type": "object",
      "patternProperties": {
        "^db\\.image\\(\\$?[a-zA-Z0-9_]+\\)\\.[a-zA-Z_][a-zA-Z0-9_.]*$": {
          "oneOf": [
            { "type": "string" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" },
            { "type": "array" }
          ]
        }
      },
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": false
    },
    "apiThenDbAlbum": {
      "type": "object",
      "patternProperties": {
        "^db\\.album\\(\\$?[a-zA-Z0-9_]+\\)\\.[a-zA-Z_][a-zA-Z0-9_.]*$": {
          "oneOf": [
            { "type": "string" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        }
      },
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": false
    },
    "apiThenItem": {
      "oneOf": [
        { "$ref": "#/definitions/apiThenResponseStatus" },
        { "$ref": "#/definitions/apiThenResponseField" },
        { "$ref": "#/definitions/apiThenFileExists" },
        { "$ref": "#/definitions/apiThenFileAbsent" },
        { "$ref": "#/definitions/apiThenDbImage" },
        { "$ref": "#/definitions/apiThenDbAlbum" }
      ]
    },
    "uiWhenNavigate": {
      "type": "object",
      "properties": {
        "navigate": { "type": "string" }
      },
      "required": ["navigate"],
      "additionalProperties": false
    },
    "uiWhenClick": {
      "type": "object",
      "properties": {
        "click": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["click"],
      "additionalProperties": false
    },
    "uiWhenFill": {
      "type": "object",
      "properties": {
        "fill": { "type": "string", "pattern": "^[a-z]+/" },
        "value": { "type": "string" }
      },
      "required": ["fill", "value"],
      "additionalProperties": false
    },
    "uiWhenSelect": {
      "type": "object",
      "properties": {
        "select": { "type": "string", "pattern": "^[a-z]+/" },
        "option": { "type": "string" }
      },
      "required": ["select", "option"],
      "additionalProperties": false
    },
    "uiWhenSubmit": {
      "type": "object",
      "properties": {
        "submit": { "type": "boolean", "const": true }
      },
      "required": ["submit"],
      "additionalProperties": false
    },
    "uiWhenItem": {
      "oneOf": [
        { "$ref": "#/definitions/uiWhenNavigate" },
        { "$ref": "#/definitions/uiWhenClick" },
        { "$ref": "#/definitions/uiWhenFill" },
        { "$ref": "#/definitions/uiWhenSelect" },
        { "$ref": "#/definitions/uiWhenSubmit" }
      ]
    },
    "uiThenVisible": {
      "type": "object",
      "properties": {
        "ui.visible": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["ui.visible"],
      "additionalProperties": false
    },
    "uiThenHidden": {
      "type": "object",
      "properties": {
        "ui.hidden": { "type": "string", "pattern": "^[a-z]+/" }
      },
      "required": ["ui.hidden"],
      "additionalProperties": false
    },
    "uiThenText": {
      "type": "object",
      "properties": {
        "ui.text": { "type": "string", "pattern": "^[a-z]+/" },
        "contains": { "type": "string" }
      },
      "required": ["ui.text", "contains"],
      "additionalProperties": false
    },
    "uiThenToast": {
      "type": "object",
      "properties": {
        "ui.toast": { "type": "object" },
        "type": { "type": "string", "enum": ["error", "success", "warning"] },
        "contains": { "type": "string" }
      },
      "required": ["ui.toast", "type", "contains"],
      "additionalProperties": false
    },
    "uiThenModal": {
      "type": "object",
      "properties": {
        "ui.modal": { "type": "string", "enum": ["open", "closed"] }
      },
      "required": ["ui.modal"],
      "additionalProperties": false
    },
    "uiThenRoute": {
      "type": "object",
      "properties": {
        "ui.route": { "type": "string" }
      },
      "required": ["ui.route"],
      "additionalProperties": false
    },
    "uiThenAriaSnapshot": {
      "type": "object",
      "properties": {
        "ui.aria_snapshot": { "type": "string" }
      },
      "required": ["ui.aria_snapshot"],
      "additionalProperties": false
    },
    "uiThenItem": {
      "oneOf": [
        { "$ref": "#/definitions/uiThenVisible" },
        { "$ref": "#/definitions/uiThenHidden" },
        { "$ref": "#/definitions/uiThenText" },
        { "$ref": "#/definitions/uiThenToast" },
        { "$ref": "#/definitions/uiThenModal" },
        { "$ref": "#/definitions/uiThenRoute" },
        { "$ref": "#/definitions/uiThenAriaSnapshot" }
      ]
    },
    "apiScenario": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "given": {
          "type": "array",
          "items": { "$ref": "#/definitions/givenItem" },
          "minItems": 0
        },
        "when": {
          "oneOf": [
            { "$ref": "#/definitions/apiCall" },
            {
              "type": "array",
              "items": { "$ref": "#/definitions/apiCall" },
              "minItems": 1
            }
          ]
        },
        "then": {
          "type": "array",
          "items": { "$ref": "#/definitions/apiThenItem" },
          "minItems": 1
        }
      },
      "required": ["name", "when", "then"],
      "additionalProperties": false
    },
    "uiScenario": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "given": {
          "type": "array",
          "items": { "$ref": "#/definitions/givenItem" },
          "minItems": 0
        },
        "when": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiWhenItem" },
          "minItems": 1
        },
        "then": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiThenItem" },
          "minItems": 1
        }
      },
      "required": ["name", "when", "then"],
      "additionalProperties": false
    }
  }
}
